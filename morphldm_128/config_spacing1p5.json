{
    "run_name": "example_spacing1p5",
    "dataset_type":"CSV",
    "csv_path":"../data/processed_parts/whole_brain_0206.csv",
    "data_root":"..",
    "data_split_json_path":"../data/patient_splits_image_ids_75_10_15.json",
    "conditions": ["age", "sex"],
    "n_samples": "ALL",
    "pad_k": 32,
    "metadata_dim": 2,
    "channel": 0,
    "spacing": [1.5, 1.5, 1.5],
    "spatial_dims": 3,
    "image_channels": 1,
    "latent_channels": 8,
    "latent_shape": [32, 32, 32],
    "train_steps_per_epoch": 100,
    "val_steps_per_epoch": 100,
    "img_size": [128, 128, 128],
    "num_workers": 2,
    "age_normalization": "min-max",
    "sample_balanced_age_for_training": true,
    "use_wandb": false,
    "use_amp": true,
    "autoencoder_ckpt_name": "best",
    "autoencoder_ckpt_path": "./example_spacing1p5/autoencoder/autoencoder_500.pt",
    "debug_one_sample": false,
    "debug_mode": false,
    "autoencoder_def": {
        "_target_": "morphldm.autoencoderkl.AutoencoderKLConditionalTemplateRegistration",
        "spatial_dims": "@spatial_dims",
        "in_channels": 2,
        "out_channels": 3,
        "latent_channels": "@latent_channels",
        "num_channels": [
            64,
            128,
            256
        ],
        "num_res_blocks": 2,
        "norm_num_groups": 32,
        "norm_eps": 1e-06,
        "attention_levels": [
            false,
            false,
            false
        ],
        "with_encoder_nonlocal_attn": false,
        "with_decoder_nonlocal_attn": false,
        "diffeomorphic": false,
        "template_shape": [1, 128, 128, 128],
        "template_generator_type": "unetdecoderhalfrelu",
        "metadata_dim": "@metadata_dim"
    },
    "autoencoder_train": {
        "batch_size": 1,
        "random_crop":false,
        "lr": 1e-4,
        "perceptual_weight": 0,
        "kl_weight": 1e-6,
        "warm_up_n_epochs": 0,
        "adv_weight": 0.005,
        "quantization_weight": 0.0,
        "displace_weight": 1,
        "recon_loss": "l1",
        "n_epochs": 500,
        "val_interval": 50,
        "grad_weight": 2,
        "diffeomorphic": false
    },
    "diffusion_def": {
        "_target_": "generative.networks.nets.DiffusionModelUNet",
        "spatial_dims": "@spatial_dims",
        "in_channels": "@latent_channels",
        "out_channels": "@latent_channels",
        "num_channels":[384, 512, 512],
        "attention_levels":[false, true, true],
        "num_head_channels":[0, 64, 64],
        "num_res_blocks": 2,
        "with_conditioning": true,
        "cross_attention_dim": 2
    },
    "diffusion_train": {
        "batch_size": 1,
        "lr": 1e-5,
        "lr_scheduler_milestones": [50, 1000],
        "n_epochs": 1200,
        "val_interval": 1,
        "sample_every_steps": 5000,
        "save_sample_slices": false,
        "save_sample_nifti": true,
        "conditioning_file":"/simurgh/u/fangruih/monai-tutorials/generative/3d_ldm/conditioning/fmriresults01.txt",
        "expand_token_times": 100,
        "gradient_clipping": true,
        "max_norm": 1.0,
        "save_every_epoch": false,
        "save_ckpt_every": 5000
    },
    "NoiseScheduler": {
        "schedule": "scaled_linear_beta",
        "num_train_timesteps": 1000,
        "beta_start": 0.0015,
        "beta_end": 0.0195,
        "clip_sample": false
    }
}
